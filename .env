# PostgreSQL Konfiguration
POSTGRES_DB=mydatabase
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# pgAdmin Konfiguration
PGADMIN_DEFAULT_EMAIL=admin@museum.local
PGADMIN_DEFAULT_PASSWORD=admin123

# Backend API Konfiguration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydatabase
DB_USER=user
DB_PASSWORD=password

# Optional: JWT Secret für Backend
JWT_SECRET=your_super_secure_jwt_secret_key_here_please_change_in_production

# Optional: Mistral API Key für KI-Features
MISTRAL_API_KEY=your_mistral_api_key_here